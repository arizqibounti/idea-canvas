# ── ThoughtClaw Environment Variables ────────────────────────

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Firebase client config (required for auth - baked into React build)
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id

# Server port (default: 5001 in dev, 8080 in Docker)
PORT=5001

# Enable auth enforcement (required for production, omit for local dev)
# ENABLE_AUTH=true

# Access control — restrict to specific emails and/or email domains
# Comma-separated. Leave both empty to allow all authenticated users.
# ALLOWED_EMAILS=alice@gmail.com,bob@outlook.com
# ALLOWED_DOMAINS=mycompany.com,partner.org

# CORS allowed origins (comma-separated, leave empty for dev = allow all)
# ALLOWED_ORIGINS=https://your-domain.com

# API URL for client (leave empty for same-origin in production)
# REACT_APP_API_URL=http://localhost:5001
